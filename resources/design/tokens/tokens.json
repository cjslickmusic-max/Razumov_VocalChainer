{
  "$description": "Canonical design tokens for Razumov VocalChainer. Source of truth: edit this file first, then sync tokens.css and Source/ui/DesignTokens.h (opaque ARGB for JUCE). Inspired by Design Tokens Community Group format ($type, $value, $description).",
  "color": {
    "background": {
      "editor": {
        "$type": "color",
        "$value": "#e6e9ef",
        "$description": "Main editor window fill (PluginEditor::paint fillAll); light glass theme"
      },
      "deep": {
        "$type": "color",
        "$value": "#0a0a14",
        "$description": "Deepest OLED-style base for web prototypes and future gradient roots"
      },
      "chainStrip": {
        "$type": "color",
        "$value": "#252830",
        "$description": "Chain strip panel behind signal-path cards"
      },
      "node": {
        "$type": "color",
        "$value": "#1e2229",
        "$description": "Default chain node card fill"
      },
      "mergeNode": {
        "$type": "color",
        "$value": "#222630",
        "$description": "Parallel merge junction card fill"
      },
      "glassTint": {
        "$type": "color",
        "$value": "#1e1b4b",
        "$description": "Indigo tint for glass-style overlays (web); JUCE: layered translucent fills"
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "#e8eaed",
        "$description": "Primary labels on dark panels"
      },
      "secondary": {
        "$type": "color",
        "$value": "#8892a0",
        "$description": "Secondary copy, hints"
      },
      "muted": {
        "$type": "color",
        "$value": "#94a3b8",
        "$description": "Muted body text in HTML prototypes"
      },
      "label": {
        "$type": "color",
        "$value": "#aab4c0",
        "$description": "ComboBox / static label next to controls"
      },
      "inverse": {
        "$type": "color",
        "$value": "#f8fafc",
        "$description": "High-contrast text on very dark or glass layers (prototypes)"
      },
      "tertiary": {
        "$type": "color",
        "$value": "#7a8490",
        "$description": "Build line / de-emphasized meta text"
      },
      "caption": {
        "$type": "color",
        "$value": "#6a7480",
        "$description": "Mic profile hint line"
      },
      "title": {
        "$type": "color",
        "$value": "#ffffff",
        "$description": "Editor title bar product name"
      }
    },
    "surface": {
      "micPreviewInner": {
        "$type": "color",
        "$value": "#252b34",
        "$description": "Mic profile preview inner rounded rect"
      },
      "moduleBackdrop": {
        "$type": "color",
        "$value": "#1e2229",
        "$description": "Module section rounded panel (same as node)"
      }
    },
    "accent": {
      "signal": {
        "$type": "color",
        "$value": "#6c9fd2",
        "$description": "Signal path: wires, default node outline, primary interactive blue"
      },
      "selection": {
        "$type": "color",
        "$value": "#9fd2ff",
        "$description": "Selected chain slot outline and glow"
      },
      "cta": {
        "$type": "color",
        "$value": "#f97316",
        "$description": "Product accent: highlights, parallel labels, emphasis (warm orange)"
      },
      "bypass": {
        "$type": "color",
        "$value": "#e89868",
        "$description": "Bypass state badge text"
      },
      "merge": {
        "$type": "color",
        "$value": "#a78bfa",
        "$description": "Parallel merge / routing emphasis (legend, badges)"
      },
      "mergeText": {
        "$type": "color",
        "$value": "#c4b5fd",
        "$description": "Readable text on merge-tinted chips"
      },
      "mergeSoft": {
        "$type": "color",
        "$value": "rgba(167, 139, 250, 0.15)",
        "$description": "Merge badge background"
      },
      "mergeBorder": {
        "$type": "color",
        "$value": "rgba(167, 139, 250, 0.45)",
        "$description": "Merge badge border"
      }
    },
    "border": {
      "subtle": {
        "$type": "color",
        "$value": "rgba(255, 255, 255, 0.08)",
        "$description": "Glass card borders (web); JUCE approximate with opacity on white"
      },
      "glassHighlight": {
        "$type": "color",
        "$value": "rgba(255, 255, 255, 0.06)",
        "$description": "Inner highlight on glass surfaces"
      },
      "micPreview": {
        "$type": "color",
        "$value": "#4a5568",
        "$description": "Mic preview outer stroke"
      },
      "modulePanel": {
        "$type": "color",
        "$value": "#353d4a",
        "$description": "Module backdrop outline"
      }
    },
    "control": {
      "rotaryOutline": {
        "$type": "color",
        "$value": "#353d48",
        "$description": "Default rotary track outline (styleRotary)"
      }
    },
    "macro": {
      "sectionLabel": {
        "$type": "color",
        "$value": "#c8d0dc",
        "$description": "Macros section heading"
      },
      "glue": { "$type": "color", "$value": "#c080a0" },
      "air": { "$type": "color", "$value": "#80c0c8" },
      "sibilance": { "$type": "color", "$value": "#d0a868" },
      "presence": { "$type": "color", "$value": "#a8d080" },
      "punch": { "$type": "color", "$value": "#e88860" },
      "body": { "$type": "color", "$value": "#b89870" },
      "smooth": { "$type": "color", "$value": "#8898d0" },
      "density": { "$type": "color", "$value": "#78b0a0" }
    },
    "knob": {
      "micAmount": { "$type": "color", "$value": "#9a86d4" },
      "gain": { "$type": "color", "$value": "#6c9fd2" },
      "lowpass": { "$type": "color", "$value": "#8fd28c" },
      "deess": { "$type": "color", "$value": "#d2a86c" },
      "opto": { "$type": "color", "$value": "#6cb8d2" },
      "fet": { "$type": "color", "$value": "#d26c8c" },
      "vca": { "$type": "color", "$value": "#b8d26c" },
      "exciter": { "$type": "color", "$value": "#e0c080" },
      "spectral": { "$type": "color", "$value": "#9a9ae0" }
    },
    "gradient": {
      "heroIndigo": {
        "$type": "color",
        "$value": "rgba(49, 46, 129, 0.45)",
        "$description": "Radial hero glow (web prototypes)"
      },
      "heroCta": {
        "$type": "color",
        "$value": "rgba(249, 115, 22, 0.06)",
        "$description": "Secondary warm vignette (web)"
      }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "12px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "space": {
    "xs": { "$type": "dimension", "$value": "4px" },
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "12px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "xl": { "$type": "dimension", "$value": "24px" }
  },
  "font": {
    "family": {
      "display": {
        "$type": "fontFamily",
        "$value": "Outfit",
        "$description": "Web prototypes: node titles, product name"
      },
      "body": {
        "$type": "fontFamily",
        "$value": "Source Sans 3",
        "$description": "Web prototypes: body UI"
      },
      "juce": {
        "$type": "fontFamily",
        "$value": "System / JUCE default",
        "$description": "Native plugin uses JUCE LookAndFeel fonts until embedded custom fonts ship"
      }
    }
  },
  "motion": {
    "easing": {
      "standard": {
        "$type": "cubicBezier",
        "$value": [0.16, 1, 0.3, 1]
      }
    },
    "duration": {
      "fast": { "$type": "duration", "$value": "200ms" },
      "medium": { "$type": "duration", "$value": "300ms" }
    }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": "0 24px 48px rgba(0, 0, 0, 0.45)"
    }
  }
}
